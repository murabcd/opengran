# Deployment used by `npx convex dev`
CONVEX_DEPLOYMENT=
CONVEX_SITE_URL=

OPENAI_API_KEY=

# Client-side Convex URLs for the Vite app
VITE_CONVEX_URL=
VITE_CONVEX_SITE_URL=

# Public URL for the marketing site metadata
VITE_MARKETING_SITE_URL=

# Better Auth runs on the Convex deployment. Set these with `npx convex env set`
BETTER_AUTH_SECRET=

SITE_URL=http://127.0.0.1:3000

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
