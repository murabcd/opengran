{
  "name": "desktop",
  "productName": "OpenGran",
  "version": "0.1.0",
  "description": "OpenGran desktop app",
  "author": "OpenGran",
  "private": true,
  "type": "module",
  "main": "./src/main.mjs",
  "scripts": {
    "dev": "node ./scripts/dev.mjs",
    "dev:bundled": "node ./scripts/dev-bundled.mjs",
    "build": "node ./scripts/build.mjs",
    "package:mac:dir": "electron-builder --mac dir",
    "package:mac": "electron-builder --mac dmg",
    "package:mac:release": "electron-builder --mac --publish always",
    "generate:app-icon": "node ./scripts/generate-app-icon.mjs",
    "generate:tray-icons": "electron ./scripts/generate-tray-icons.mjs",
    "lint": "biome lint src scripts package.json",
    "lint:fix": "biome lint --write src scripts package.json",
    "check": "biome check src scripts package.json",
    "check:fix": "biome check --write src scripts package.json",
    "format": "biome format --write src scripts package.json",
    "test": "node -e \"process.exit(0)\"",
    "typecheck": "node --check src/main.mjs && node --check src/local-server.mjs && node --check src/auth-client.mjs && node --check src/network.mjs && node --check src/runtime-config.mjs && node --check src/env.mjs && node --check src/preload.cjs && node --check scripts/dev.mjs && node --check scripts/dev-bundled.mjs && node --check scripts/build.mjs && node --check scripts/build-system-audio-helper.mjs && node --check scripts/forward-electron-output.mjs && node --check scripts/generate-app-icon.mjs && node --check scripts/generate-tray-icons.mjs"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.41",
    "@posthog/agent-toolkit": "^0.2.4",
    "ai": "^6.0.116",
    "conf": "^15.0.2",
    "convex": "^1.34.0",
    "electron-updater": "^6.6.2",
    "ws": "^8.18.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "electron": "^36.3.2",
    "electron-builder": "^26.0.12",
    "web": "workspace:*"
  },
  "build": {
    "appId": "dev.opengran.desktop",
    "productName": "OpenGran",
    "directories": {
      "output": "release"
    },
    "extraMetadata": {
      "main": ".bundle-root/apps/desktop/dist/main.mjs"
    },
    "files": [
      ".bundle-root/**/*",
      "package.json"
    ],
    "asarUnpack": [
      ".bundle-root/apps/desktop/dist/bin/**"
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.productivity",
      "icon": "build/icon.icns",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "extendInfo": {
        "NSMicrophoneUsageDescription": "During your meetings, OpenGran transcribes your microphone.",
        "NSAudioCaptureUsageDescription": "During your meetings, OpenGran transcribes your system audio output."
      },
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "murabcd",
        "repo": "opengran",
        "releaseType": "release"
      }
    ]
  }
}
