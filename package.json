{
  "name": "opengran",
  "version": "0.0.1",
  "private": true,
  "packageManager": "bun@1.3.10",
  "scripts": {
    "build": "turbo run build",
    "changeset": "changeset",
    "release:prepare": "bun install --frozen-lockfile && bun run version-packages && bun run check && bun run typecheck && bun run test",
    "version-packages": "changeset version",
    "dev": "concurrently --kill-others-on-fail -n web,desktop,convex -c green,cyan,magenta \"bun run dev:web\" \"bun run dev:desktop\" \"bunx convex dev\"",
    "dev:marketing": "turbo run dev --filter=marketing",
    "dev:web": "OPENGRAN_ENV_MODE=local turbo run dev --filter=web",
    "dev:desktop": "OPENGRAN_ENV_MODE=local bun --filter=desktop run dev",
    "dev:desktop:native": "OPENGRAN_ENV_MODE=local bun --filter=desktop run dev:bundled",
    "dist:mac": "bun --filter=web run build:desktop && bun --filter=desktop run build && bun --filter=desktop run package:mac",
    "release:mac": "bun --filter=web run build:desktop && bun --filter=desktop run build && bun --filter=desktop run package:mac:release",
    "lint": "turbo run lint",
    "check": "turbo run check",
    "format": "turbo run format",
    "prepare": "husky",
    "test": "turbo run test && bun run test:convex",
    "test:convex": "bun run --cwd convex test:once",
    "typecheck": "turbo run typecheck && bun run typecheck:convex",
    "typecheck:convex": "bun run --cwd convex typecheck",
    "preview": "turbo run preview --filter=web",
    "preview:marketing": "turbo run preview --filter=marketing"
  },
  "devDependencies": {
    "@edge-runtime/vm": "^5.0.0",
    "@biomejs/biome": "2.4.9",
    "@changesets/cli": "^2.30.0",
    "@types/node": "^24.12.0",
    "concurrently": "^9.2.1",
    "convex-test": "^0.0.44",
    "husky": "^9.1.7",
    "turbo": "^2.8.21",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "@ai-sdk/openai": "^3.0.41",
    "@convex-dev/better-auth": "^0.11.3",
    "@posthog/agent-toolkit": "^0.2.4",
    "ai": "^6.0.116",
    "better-auth": "1.5.5",
    "canvas-confetti": "^1.9.4",
    "convex": "^1.34.1",
    "zod": "^4.1.12"
  }
}
