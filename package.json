{
  "name": "openmeet",
  "version": "0.0.1",
  "private": true,
  "packageManager": "bun@1.3.10",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=web",
    "dev:desktop": "turbo run dev --filter=web --filter=desktop",
    "lint": "turbo run lint",
    "check": "turbo run check",
    "format": "turbo run format",
    "typecheck": "turbo run typecheck",
    "preview": "turbo run preview --filter=web"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.8",
    "turbo": "^2.8.17",
    "typescript": "~5.9.3"
  },
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
