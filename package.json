{
  "name": "opengran",
  "version": "0.0.1",
  "private": true,
  "packageManager": "bun@1.3.10",
  "scripts": {
    "build": "turbo run build",
    "dev": "concurrently --kill-others-on-fail -n desktop,convex -c cyan,magenta \"bun run dev:desktop\" \"bunx convex dev\"",
    "dev:web": "turbo run dev --filter=web",
    "dev:desktop": "turbo run dev --filter=web --filter=desktop",
    "lint": "turbo run lint",
    "check": "turbo run check",
    "format": "turbo run format",
    "prepare": "husky",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "preview": "turbo run preview --filter=web"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.8",
    "@types/node": "^24.12.0",
    "concurrently": "^9.2.1",
    "husky": "^9.1.7",
    "turbo": "^2.8.17",
    "typescript": "~5.9.3"
  },
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "@convex-dev/better-auth": "^0.11.2",
    "better-auth": "1.5.5",
    "canvas-confetti": "^1.9.4",
    "convex": "^1.34.0"
  }
}
